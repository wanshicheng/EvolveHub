{
  "name": "evolvehub-monorepo",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "monorepo",
    "turbo",
    "evolvehub",
    "vue",
    "vue admin",
    "vue3"
  ],
  "homepage": "https://github.com/evolvehub",
  "bugs": "https://github.com/evolvehub/issues",
  "repository": "evolvehub/evolvehub.git",
  "license": "MIT",
  "author": {
    "name": "EvolveHub",
    "email": "",
    "url": ""
  },
  "type": "module",
  "scripts": {
    "dev": "turbo-run dev",
    "dev:ele": "pnpm -F @vben/web-ele run dev",
    "dev:mock": "pnpm -F @vben/backend-mock run dev",
    "dev:all": "concurrently \"pnpm run dev:mock\" \"pnpm run dev:ele\"",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build",
    "build:ele": "pnpm run build --filter=@vben/web-ele",
    "build:mock": "pnpm run build --filter=@vben/backend-mock",
    "preview": "turbo-run preview",
    "lint": "vsh lint",
    "format": "vsh lint --format",
    "check:type": "turbo run typecheck",
    "test:unit": "vitest run --dom",
    "clean": "node ./scripts/clean.mjs",
    "reinstall": "pnpm clean --del-lock && pnpm install",
    "postinstall": "pnpm -r run stub --if-present",
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || pnpm exec lefthook install"
  },
  "devDependencies": {
    "@vben/commitlint-config": "workspace:*",
    "@vben/eslint-config": "workspace:*",
    "@vben/oxfmt-config": "workspace:*",
    "@vben/oxlint-config": "workspace:*",
    "@vben/stylelint-config": "workspace:*",
    "@vben/tailwind-config": "workspace:*",
    "@vben/tsconfig": "workspace:*",
    "@vben/turbo-run": "workspace:*",
    "@vben/vite-config": "workspace:*",
    "@vben/vsh": "workspace:*",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vue/test-utils": "catalog:",
    "cross-env": "catalog:",
    "cspell": "catalog:",
    "happy-dom": "catalog:",
    "is-ci": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@tsdown/css": "catalog:",
    "concurrently": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || ^22.18.0 || ^24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
